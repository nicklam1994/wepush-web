# WeChat Official Account 測試號配置
# 前往 https://mp.weixin.qq.com/debug/cgi-bin/sandbox?t=sandbox/login 獲取
WECHAT_APPID=wx0000000000000000
WECHAT_APPSECRET=00000000000000000000000000000000

# OpenWeatherMap API Key（可選，免費版 60次/分鐘）
# https://openweathermap.org/api
OPENWEATHERMAP_KEY=

# 高德地圖 API Key（可選，用於天氣 + POI 搜索）
# https://console.amap.com/
AMAP_KEY=

# Server
HOST=0.0.0.0
PORT=8765
